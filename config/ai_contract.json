{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentAIAnalysis",
  "type": "object",
  "required": [
    "market_relevance",
    "resolution_relevance",
    "source_quality",
    "novelty",
    "direction",
    "confidence",
    "event_type",
    "directly_affects_resolution",
    "summary",
    "why",
    "entities",
    "time_sensitivity"
  ],
  "additionalProperties": false,
  "properties": {
    "market_relevance": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "resolution_relevance": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "source_quality": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "novelty": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "direction": {
      "type": "string",
      "enum": [
        "positive",
        "negative",
        "neutral",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "event_type": {
      "type": "string",
      "enum": [
        "announcement",
        "rumor",
        "data_release",
        "legal",
        "personnel",
        "other"
      ]
    },
    "directly_affects_resolution": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "why": {
      "type": "string",
      "minLength": 1
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "time_sensitivity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
